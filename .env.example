# Grocery Optimizer - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================================================
# DATABASE CONFIGURATION (Neon.tech PostgreSQL + TimescaleDB)
# ============================================================================
# Get this from your Neon.tech project dashboard
# Format: postgresql://username:password@host/database?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/groceryoptimizer

# ============================================================================
# REDIS CONFIGURATION (Upstash Redis)
# ============================================================================
# Get this from your Upstash Redis console
# Format: redis://default:password@host:port
REDIS_URL=redis://default:password@region-xxx.upstash.io:6379
REDIS_ENABLED=False

# ============================================================================
# HUGGING FACE API (for AI Models)
# ============================================================================
# Get your API token from https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# OLLAMA CONFIGURATION (Local LLM Server)
# ============================================================================
# URL for your Ollama server (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama models to use
OLLAMA_CHEF_MODEL=smollm:1.7b
OLLAMA_SOUS_CHEF_MODEL=smollm:360m
OLLAMA_NUTRITIONIST_MODEL=smollm:360m

# Per-request ceiling (seconds) for agent LLM calls
OLLAMA_REQUEST_TIMEOUT=600

# ============================================================================
# MLFLOW TRACKING (Experiment Tracking)
# ============================================================================
# URL for MLflow tracking server
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=grocery-meal-planner

# Or use a remote MLflow server
# MLFLOW_TRACKING_URI=https://your-mlflow-server.com

# ============================================================================
# FLIPP API CONFIGURATION
# ============================================================================
# Flipp API credentials (to be obtained from Flipp)
FLIPP_API_KEY=your_flipp_api_key_here
FLIPP_API_URL=https://api.flipp.com/v2

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Environment: development, staging, production
ENVIRONMENT=development
DEBUG=True

# Secret key for JWT tokens and session management
SECRET_KEY=your-secret-key-change-this-in-production

# API rate limiting
API_RATE_LIMIT=100  # requests per minute

# ============================================================================
# CELERY CONFIGURATION (Background Tasks)
# ============================================================================
# Broker URL (uses Upstash Redis)
CELERY_BROKER_URL=redis://default:password@region-xxx.upstash.io:6379
CELERY_RESULT_BACKEND=redis://default:password@region-xxx.upstash.io:6379

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ============================================================================
# GITHUB CODESPACES (auto-detected)
# ============================================================================
# These are automatically set by GitHub Codespaces
# CODESPACES=true
# CODESPACE_NAME=your-codespace-name

# ============================================================================
# COST TRACKING
# ============================================================================
# Enable detailed cost tracking for API calls
ENABLE_COST_TRACKING=true

# Cost per 1M tokens for different models (USD)
COST_SMOLLM_1_7B=0.001
COST_SMOLLM_360M=0.0005
COST_SMOLLM_135M=0.0002

# ============================================================================
# CACHING SETTINGS
# ============================================================================
# Cache TTL in seconds
CACHE_TTL_DEALS=21600        # 6 hours
CACHE_TTL_RECIPES=86400       # 24 hours
CACHE_TTL_STORES=604800       # 7 days

# ============================================================================
# TESTING
# ============================================================================
# Use separate test database for running tests
TEST_DATABASE_URL=postgresql://user:password@host/groceryoptimizer_test
